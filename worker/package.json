{
  "name": "recon-api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "migrate": "wrangler d1 migrations apply RECON_DB",
    "migrate:local": "wrangler d1 migrations apply RECON_DB --local",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@vitest/coverage-istanbul": "^4.1.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.14.0"
  }
}
