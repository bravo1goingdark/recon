/*
  # Baseline security headers applied to every asset.
  #
  # X-Frame-Options + CSP frame-ancestors: clickjacking defence. `DENY`
  # forbids embedding the site in any iframe, anywhere. We don't expose
  # anything that should be embeddable.
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  # Block legacy features the landing/dashboard never use. Short list
  # keeps the header readable and avoids the noise of exhaustive `=()`.
  #
  # accelerometer / gyroscope are explicitly allowed for Razorpay's
  # checkout iframe — its SDK uses motion sensors for device-fingerprint
  # / fraud-risk signals during mandate authorisation. Browsers default-
  # deny these features in cross-origin iframes unless the parent
  # explicitly delegates them, so without this the Razorpay modal logs
  # "blocked by permissions policy" and risk scoring degrades.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), accelerometer=(self "https://checkout.razorpay.com" "https://api.razorpay.com"), gyroscope=(self "https://checkout.razorpay.com" "https://api.razorpay.com")
  # HSTS 2 years + includeSubDomains + preload-eligible. Once preload is
  # submitted, browsers refuse plain-HTTP for mcprecon.pages.dev forever.
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # Isolate our origin from other-window references (Spectre-class +
  # share-target abuse mitigation).
  Cross-Origin-Opener-Policy: same-origin
  # Content Security Policy. `'unsafe-inline'` on style-src is required
  # because the dashboard and landing still inline small style blocks;
  # script-src stays strict (no unsafe-inline, no unsafe-eval) — all
  # first-party JS lives under /js/ same-origin. Razorpay's checkout
  # SDK and iframe are explicitly allowed under their own domains so
  # pricing.js can load the widget without opening the door to
  # arbitrary third-party scripts. form-action allows the GitHub OAuth
  # top-level redirect target; everything else POSTs same-origin.
  # Google Fonts: style-src allows the @font-face stylesheet at
  # fonts.googleapis.com; font-src allows the font binaries served
  # from fonts.gstatic.com (Instrument Serif / Geist / JetBrains Mono).
  Content-Security-Policy: default-src 'self'; script-src 'self' https://checkout.razorpay.com https://cdn.razorpay.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://mcprecon.pages.dev https://api.razorpay.com https://lumberjack.razorpay.com https://cloudflareinsights.com; frame-src https://api.razorpay.com https://checkout.razorpay.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://github.com https://api.razorpay.com

/dashboard
  Cache-Control: no-store

/login
  Cache-Control: no-store
